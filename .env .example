ENV=development
DATABASE_URL=postgresql+asyncpg://mytasco:mytasco@localhost:5433/mytasco
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=mytasco
JWT_AUDIENCE=mytasco-ai
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=45.0
OPENAI_ZDR_VERIFIED=false
CONFIRMATION_SIGNING_KEY=change-me-confirmation-key
CONFIRMATION_TTL_SECONDS=300
RUN_DEADLINE_SECONDS=90
MAX_UPLOAD_BYTES=20971520
DEFAULT_TENANT_ID=demo-mytasco
APP_CODE=MYTASCO
MOCK_ADAPTERS_ENABLED=true
HF_HOME=.cache/huggingface
HF_HUB_OFFLINE=0
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TENANT_ID=demo-mytasco
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=mytasco-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
