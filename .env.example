# =============================================================================
# My Tasco Secure Agentic RAG — environment variable template
# =============================================================================
# Copy this file to .env and fill in real values before starting the server.
# Never commit .env to version control.
#
# Loaded automatically by pydantic-settings (apps/api/src/config.py).
# =============================================================================


# -----------------------------------------------------------------------------
# Runtime environment
# -----------------------------------------------------------------------------

# One of: development | staging | production
# production mode enforces JWT_SECRET, CONFIRMATION_SIGNING_KEY, and
# MOCK_ADAPTERS_ENABLED=false; any misconfiguration raises a startup error.
ENV=development


# -----------------------------------------------------------------------------
# PostgreSQL (pgvector)
# -----------------------------------------------------------------------------
# Must point to a pgvector-enabled PostgreSQL instance.
# docker-compose default: pgvector/pgvector:pg16, db=mytasco, user=mytasco
# Driver: asyncpg (async); alembic.ini also reads this DSN.

DATABASE_URL=postgresql+asyncpg://mytasco:mytasco@localhost:5432/mytasco


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Used for idempotency-key replay cache and agent-run job queue.
# docker-compose default: redis:7 on port 6379, db index 0.

REDIS_URL=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# JWT authentication
# JWT_SECRET    — HMAC signing secret; MUST be rotated in production.
# JWT_ALGORITHM — Signing algorithm; HS256 is the supported default.
# JWT_ISSUER    — iss claim expected in every access token.
# JWT_AUDIENCE  — aud claim expected in every access token.
# -----------------------------------------------------------------------------

JWT_SECRET=change-me-in-production-32-bytes-minimum
JWT_ALGORITHM=HS256
JWT_ISSUER=mytasco
JWT_AUDIENCE=mytasco-ai


# -----------------------------------------------------------------------------
# OpenAI generation boundary
# OpenAI is the ONLY external model call; it receives only approved Evidence
# Capsules after local DLP and classification checks (see BACKEND_OPENAI_SECURITY_POLICY.md).
#
# OPENAI_ENABLED        — Master switch. false = no outbound OpenAI calls.
# OPENAI_API_KEY        — Required when OPENAI_ENABLED=true.
# OPENAI_MODEL          — Chat-completion model identifier.
# OPENAI_BASE_URL       — Override for proxies or Azure OpenAI endpoints.
# OPENAI_TIMEOUT_SECONDS — Per-request timeout in seconds.
# OPENAI_ZDR_VERIFIED   — Set true only after verifying Zero Data Retention on
#                          the OpenAI project. Required for Internal-class docs.
# -----------------------------------------------------------------------------

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=45.0
OPENAI_ZDR_VERIFIED=false


# -----------------------------------------------------------------------------
# Action confirmation tokens
# CONFIRMATION_SIGNING_KEY — HMAC key for action confirmation tokens;
#                             MUST be rotated in production.
# CONFIRMATION_TTL_SECONDS — Seconds before a confirmation token expires (default 300).
# -----------------------------------------------------------------------------

CONFIRMATION_SIGNING_KEY=change-me-confirmation-key
CONFIRMATION_TTL_SECONDS=300


# -----------------------------------------------------------------------------
# Agent run limits
# RUN_DEADLINE_SECONDS — Hard timeout for a single agent run job (default 90).
# -----------------------------------------------------------------------------

RUN_DEADLINE_SECONDS=90


# -----------------------------------------------------------------------------
# Document upload
# MAX_UPLOAD_BYTES — Maximum multipart upload size in bytes (default 20 MB).
# -----------------------------------------------------------------------------

MAX_UPLOAD_BYTES=20971520


# -----------------------------------------------------------------------------
# Tenancy
# DEFAULT_TENANT_ID — Tenant used for the demo corpus and dev requests.
#                     Must match the tenant_id in embeddings.jsonl for
#                     the ArtifactIndex to serve queries correctly.
# -----------------------------------------------------------------------------

DEFAULT_TENANT_ID=demo-mytasco

OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_LOCAL_ROOT=tmp/object_store
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=


# -----------------------------------------------------------------------------
# App-code middleware
# APP_CODE — Value of the X-App-Code header required on every API request.
#             Acts as a lightweight API-layer identifier; not a security secret.
# -----------------------------------------------------------------------------

APP_CODE=MYTASCO


# -----------------------------------------------------------------------------
# Development / scaffold flags
# MOCK_ADAPTERS_ENABLED — true enables in-process stub adapters for routes not
#                          yet wired to real services. Must be false in production.
# -----------------------------------------------------------------------------

MOCK_ADAPTERS_ENABLED=true
INTERNAL_EMBEDDINGS_ENABLED=false


# -----------------------------------------------------------------------------
# Embedding worker (embed_dataset.py / ingest_document_job)
# These are not read by pydantic-settings; they are CLI arguments or
# shell-level env vars consumed by the worker process.
#
# HF_HOME          — Local cache directory for Hugging Face model snapshots.
#                    Set to a fast, private disk; model weights stay on-prem.
# HF_HUB_OFFLINE   — Set to 1 in air-gapped / production environments to
#                    prevent any outbound download attempt.
# EMBEDDING_DEVICE — auto | cpu | cuda  (passed to Qwen3Embedder)
# EMBEDDING_BATCH_SIZE — Chunks per GPU/CPU batch (default 16).
# EMBEDDING_TENANT_ID  — Tenant bound to every produced EmbeddingRecord.
# -----------------------------------------------------------------------------

HF_HOME=.cache/huggingface
HF_HUB_OFFLINE=0
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TENANT_ID=demo-mytasco


# -----------------------------------------------------------------------------
# OpenTelemetry (optional — wiring is a TODO in apps/api/src/main.py)
# OTEL_EXPORTER_OTLP_ENDPOINT — gRPC collector endpoint, e.g. http://localhost:4317
# OTEL_SERVICE_NAME           — Service name reported to the collector.
# OTEL_SDK_DISABLED           — Set to true to suppress all telemetry in dev.
# -----------------------------------------------------------------------------

OTEL_EXPORTER_OTLP_ENDPOINT=
